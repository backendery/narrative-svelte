root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
max_line_length = 100
trim_trailing_whitespace = true

[*.{js,ts,svelte}]
indent_style = space
indent_size = 4

[*.html]
indent_style = space
indent_size = 4

[*.json]
indent_style = space
indent_size = 4

[*.md]
indent_style = space
indent_size = 4